{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.12.0/.schema/devbox.schema.json",
  "packages": [
    "docker@latest",
    "kubectl@latest",
    "skaffold@latest",
    "python312@latest",
    "kind@0.24.0"
  ],
  "env": {
    "VENV_DIR":  "venv",
    "UV_PYTHON": "venv/bin/python"
  },
  "shell": {
    "init_hook": [
      "make update-tools",
      "make install"
    ]
  }
}
